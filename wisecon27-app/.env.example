# WISEcon27 — environment config. Copy to .env.local and fill in.
# Find these in Supabase: Project → Settings → API.

# Public values (safe in the browser; protected by Row-Level Security):
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Used ONLY by scripts/seed.mjs (server-side, never shipped to the browser).
# This is the SECRET service-role key — keep it out of git and the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Web Push (Phase 6). Generate with:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
